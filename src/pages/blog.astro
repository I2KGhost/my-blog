---
import BaseHead from '../components/BaseHead.astro';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title="Blog — Ivaylo Kolev" description="Thoughts on AI automation, security research, and creative worldbuilding." />
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
<link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700&family=Outfit:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet"/>
<style is:global>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
:root{
  --bg:#07070f;--bg-card:#101020;--bg-card-hover:#141428;
  --border:rgba(255,255,255,0.06);--border-mid:rgba(255,255,255,0.1);
  --gold:#c9923a;--gold-light:#e8b46a;--teal:#3ecfbe;--purple:#8b6fff;
  --text:#ddddef;--text-muted:#55557a;--text-mid:#8888b8;
  --font-display:'Cinzel',serif;--font-body:'Outfit',sans-serif;--font-mono:'JetBrains Mono',monospace;
}
html{scroll-behavior:smooth;}
body{background:var(--bg);color:var(--text);font-family:var(--font-body);font-size:16px;line-height:1.7;min-height:100vh;overflow-x:hidden;}
#bg-canvas{position:fixed;inset:0;z-index:0;opacity:0.5;pointer-events:none;}

nav{position:fixed;top:0;left:0;right:0;z-index:100;display:flex;align-items:center;justify-content:space-between;padding:1.25rem 3rem;border-bottom:1px solid var(--border);background:rgba(7,7,15,0.82);backdrop-filter:blur(16px);}
.nav-logo{font-family:var(--font-display);font-size:0.82rem;font-weight:600;letter-spacing:0.14em;color:var(--text);text-decoration:none;text-transform:uppercase;}
.nav-logo span{color:var(--gold-light);}
.nav-links{display:flex;gap:2.5rem;list-style:none;}
.nav-links a{font-size:0.78rem;font-weight:500;letter-spacing:0.1em;color:var(--text-mid);text-decoration:none;text-transform:uppercase;transition:color 0.2s;position:relative;}
.nav-links a::after{content:'';position:absolute;bottom:-4px;left:0;right:0;height:1px;background:var(--gold-light);transform:scaleX(0);transition:transform 0.2s;transform-origin:left;}
.nav-links a:hover{color:var(--text);}
.nav-links a:hover::after,.nav-links a.active::after{transform:scaleX(1);}
.nav-links a.active{color:var(--text);}

.page-header{padding:9rem 3rem 4rem;position:relative;z-index:1;}
.page-eyebrow{font-family:var(--font-mono);font-size:0.72rem;color:var(--gold);letter-spacing:0.22em;text-transform:uppercase;margin-bottom:1rem;opacity:0;animation:fadeUp 0.6s ease forwards 0.2s;}
.page-title{font-family:var(--font-display);font-size:clamp(2.5rem,6vw,5rem);font-weight:700;line-height:1.0;color:var(--text);margin-bottom:1.25rem;opacity:0;animation:fadeUp 0.7s ease forwards 0.4s;}
.page-sub{font-size:1rem;color:var(--text-mid);max-width:520px;line-height:1.8;opacity:0;animation:fadeUp 0.7s ease forwards 0.55s;}

.divider{width:100%;height:1px;background:linear-gradient(90deg,transparent,var(--border-mid) 20%,var(--border-mid) 80%,transparent);position:relative;z-index:1;}

/* FILTER TABS */
.blog-filters{display:flex;gap:0.6rem;flex-wrap:wrap;padding:2.5rem 3rem 0;position:relative;z-index:1;}
.filter-btn{font-family:var(--font-mono);font-size:0.65rem;letter-spacing:0.12em;text-transform:uppercase;padding:6px 14px;border:1px solid var(--border-mid);border-radius:2px;color:var(--text-muted);background:transparent;cursor:pointer;transition:all 0.2s;}
.filter-btn:hover,.filter-btn.active{border-color:var(--gold);color:var(--gold-light);background:rgba(201,146,58,0.06);}

/* BLOG GRID */
.blog-section{padding:3rem 3rem 5rem;position:relative;z-index:1;}
.blog-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(340px,1fr));gap:1.5rem;}

.post-card{background:var(--bg-card);border:1px solid var(--border);border-radius:3px;padding:2rem;transition:all 0.25s ease;text-decoration:none;color:inherit;display:block;position:relative;overflow:hidden;}
.post-card::before{content:'';position:absolute;top:0;left:0;width:100%;height:2px;background:linear-gradient(90deg,var(--card-accent,var(--gold)),transparent);opacity:0;transition:opacity 0.25s;}
.post-card:hover{background:var(--bg-card-hover);border-color:rgba(201,146,58,0.2);transform:translateY(-2px);}
.post-card:hover::before{opacity:1;}

.post-meta{display:flex;align-items:center;gap:0.75rem;margin-bottom:1.1rem;flex-wrap:wrap;}
.post-date{font-family:var(--font-mono);font-size:0.65rem;color:var(--text-muted);letter-spacing:0.08em;}
.post-cat{font-family:var(--font-mono);font-size:0.62rem;letter-spacing:0.12em;text-transform:uppercase;padding:3px 8px;border-radius:2px;}
.cat-ai{background:rgba(201,146,58,0.07);color:var(--gold-light);border:1px solid rgba(201,146,58,0.18);}
.cat-security{background:rgba(62,207,190,0.07);color:var(--teal);border:1px solid rgba(62,207,190,0.18);}
.cat-creative{background:rgba(139,111,255,0.07);color:var(--purple);border:1px solid rgba(139,111,255,0.18);}
.cat-tools{background:rgba(255,255,255,0.05);color:var(--text-mid);border:1px solid var(--border-mid);}

.post-title{font-family:var(--font-display);font-size:1.1rem;font-weight:600;color:var(--text);margin-bottom:0.65rem;letter-spacing:0.03em;line-height:1.35;}
.post-excerpt{font-size:0.85rem;color:var(--text-muted);line-height:1.65;}
.post-read{font-family:var(--font-mono);font-size:0.65rem;color:var(--gold);letter-spacing:0.1em;text-transform:uppercase;margin-top:1.25rem;display:flex;align-items:center;gap:0.4rem;}
.post-read::after{content:'→';transition:transform 0.2s;}
.post-card:hover .post-read::after{transform:translateX(3px);}

/* FEATURED POST */
.post-card.featured-post{grid-column:span 2;}
.post-card.featured-post .post-title{font-size:1.45rem;}

/* COMING SOON */
.coming-soon{text-align:center;padding:5rem 3rem;position:relative;z-index:1;}
.cs-geo{margin:0 auto 2rem;opacity:0.08;}
.cs-label{font-family:var(--font-mono);font-size:0.7rem;color:var(--gold);letter-spacing:0.2em;text-transform:uppercase;margin-bottom:0.75rem;}
.cs-title{font-family:var(--font-display);font-size:1.6rem;color:var(--text);margin-bottom:0.75rem;}
.cs-sub{font-size:0.9rem;color:var(--text-muted);max-width:400px;margin:0 auto;}

footer{padding:2.5rem 3rem;border-top:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1rem;position:relative;z-index:1;}
.footer-copy{font-family:var(--font-mono);font-size:0.7rem;color:var(--text-muted);letter-spacing:0.06em;}
.footer-links{display:flex;gap:1.75rem;list-style:none;}
.footer-links a{font-family:var(--font-mono);font-size:0.7rem;letter-spacing:0.1em;text-transform:uppercase;color:var(--text-muted);text-decoration:none;transition:color 0.2s;}
.footer-links a:hover{color:var(--gold-light);}

@keyframes fadeUp{from{opacity:0;transform:translateY(20px);}to{opacity:1;transform:translateY(0);}}
.reveal{opacity:0;transform:translateY(14px);transition:opacity 0.65s ease,transform 0.65s ease;}
.reveal.visible{opacity:1;transform:none;}

@media(max-width:900px){.post-card.featured-post{grid-column:span 1;}.post-card.featured-post .post-title{font-size:1.1rem;}}
@media(max-width:768px){nav{padding:1rem 1.5rem;}.page-header,.blog-section,.blog-filters,.coming-soon{padding-left:1.5rem;padding-right:1.5rem;}footer{padding:2rem 1.5rem;flex-direction:column;align-items:flex-start;}.blog-grid{grid-template-columns:1fr;}}
</style>
</head>
<body>
<canvas id="bg-canvas"></canvas>

<nav>
  <a href="/" class="nav-logo">Ivaylo <span>Kolev</span></a>
  <ul class="nav-links">
    <li><a href="/">Home</a></li>
    <li><a href="/blog" class="active">Blog</a></li>
    <li><a href="/about">About</a></li>
  </ul>
</nav>

<div class="page-header">
  <p class="page-eyebrow">// Notes from the build log</p>
  <h1 class="page-title">Blog</h1>
  <p class="page-sub">Thoughts on AI automation, security research, tools I'm using, and the occasional deep dive into whatever has my attention.</p>
</div>

<div class="divider"></div>

<div class="blog-filters reveal">
  <button class="filter-btn active">All</button>
  <button class="filter-btn">AI & Automation</button>
  <button class="filter-btn">Security</button>
  <button class="filter-btn">Creative</button>
  <button class="filter-btn">Tools & Stack</button>
</div>

<section class="blog-section">
  <div class="blog-grid">

    <a href="#" class="post-card featured-post reveal" style="--card-accent:#c9923a;">
      <div class="post-meta">
        <span class="post-date">Apr 18, 2026</span>
        <span class="post-cat cat-ai">AI & Automation</span>
      </div>
      <h2 class="post-title">Getting Started with n8n: My First Automation That Actually Saved Time</h2>
      <p class="post-excerpt">I've been using n8n for about three months now to build workflows for my AI agency project. Here's what I learned building my first real client-ready automation — the mistakes, the wins, and what I'd do differently.</p>
      <span class="post-read">Read post</span>
    </a>

    <a href="#" class="post-card reveal" style="--card-accent:#3ecfbe;">
      <div class="post-meta">
        <span class="post-date">Apr 10, 2026</span>
        <span class="post-cat cat-security">Security</span>
      </div>
      <h2 class="post-title">Prompt Injection Explained: What It Is and Why It Matters for AI Apps</h2>
      <p class="post-excerpt">Working through TryHackMe's AI security path taught me just how fragile LLM applications can be. A breakdown of prompt injection from a builder's perspective.</p>
      <span class="post-read">Read post</span>
    </a>

    <a href="#" class="post-card reveal" style="--card-accent:#8b6fff;">
      <div class="post-meta">
        <span class="post-date">Mar 29, 2026</span>
        <span class="post-cat cat-creative">Creative</span>
      </div>
      <h2 class="post-title">Building a Fantasy World From Scratch: The Drekoria Origin Story</h2>
      <p class="post-excerpt">What started as a novel idea in my teens became something much bigger. How Drekoria grew from a single empire name into a full creative universe — and where it's going next.</p>
      <span class="post-read">Read post</span>
    </a>

    <a href="#" class="post-card reveal" style="--card-accent:#c9923a;">
      <div class="post-meta">
        <span class="post-date">Mar 15, 2026</span>
        <span class="post-cat cat-tools">Tools & Stack</span>
      </div>
      <h2 class="post-title">My Privacy Stack in 2026: What I Use, What I Dropped, and Why</h2>
      <p class="post-excerpt">Migrating away from Google services took about six months. Here's the full breakdown of every tool I switched to, what worked, and what was honestly just inconvenient.</p>
      <span class="post-read">Read post</span>
    </a>

    <a href="#" class="post-card reveal" style="--card-accent:#3ecfbe;">
      <div class="post-meta">
        <span class="post-date">Feb 28, 2026</span>
        <span class="post-cat cat-ai">AI & Automation</span>
      </div>
      <h2 class="post-title">AWS AI & ML Scholars: Week One Review</h2>
      <p class="post-excerpt">Applied and got in. The challenge phase is more structured than I expected — and the hands-on work with Amazon Bedrock is immediately applicable. First impressions.</p>
      <span class="post-read">Read post</span>
    </a>

  </div>
</section>

<div class="divider"></div>

<footer>
  <p class="footer-copy">© 2026 Ivaylo Kolev. All rights reserved.</p>
  <ul class="footer-links">
    <li><a href="#" target="_blank">YouTube</a></li>
    <li><a href="#" target="_blank">Instagram</a></li>
    <li><a href="#" target="_blank">Patreon</a></li>
    <li><a href="#" target="_blank">GitHub</a></li>
  </ul>
</footer>

<script>
const canvas=document.getElementById('bg-canvas'),ctx=canvas.getContext('2d');let W,H,particles=[];
const COLORS=['rgba(201,146,58,','rgba(62,207,190,','rgba(139,111,255,'];
function resize(){W=canvas.width=window.innerWidth;H=canvas.height=window.innerHeight;}
function Particle(){this.x=Math.random()*W;this.y=Math.random()*H;this.vx=(Math.random()-0.5)*0.2;this.vy=(Math.random()-0.5)*0.2;this.r=Math.random()*1.3+0.4;this.color=COLORS[Math.floor(Math.random()*3)];this.alpha=Math.random()*0.4+0.07;}
function init(){resize();particles=[];const c=Math.floor(W*H/14000);for(let i=0;i<c;i++)particles.push(new Particle());}
function draw(){ctx.clearRect(0,0,W,H);particles.forEach(p=>{p.x+=p.vx;p.y+=p.vy;if(p.x<0)p.x=W;if(p.x>W)p.x=0;if(p.y<0)p.y=H;if(p.y>H)p.y=0;ctx.beginPath();ctx.arc(p.x,p.y,p.r,0,Math.PI*2);ctx.fillStyle=p.color+p.alpha+')';ctx.fill();});for(let i=0;i<particles.length;i++)for(let j=i+1;j<particles.length;j++){const dx=particles[i].x-particles[j].x,dy=particles[i].y-particles[j].y,d=Math.sqrt(dx*dx+dy*dy);if(d<100){ctx.beginPath();ctx.strokeStyle='rgba(201,146,58,'+(0.05*(1-d/100))+')';ctx.lineWidth=0.5;ctx.moveTo(particles[i].x,particles[i].y);ctx.lineTo(particles[j].x,particles[j].y);ctx.stroke();}}requestAnimationFrame(draw);}
window.addEventListener('resize',init);init();draw();
const obs=new IntersectionObserver(e=>{e.forEach(x=>{if(x.isIntersecting){x.target.classList.add('visible');obs.unobserve(x.target);}});},{threshold:0.08});
document.querySelectorAll('.reveal').forEach(el=>obs.observe(el));
document.querySelectorAll('.filter-btn').forEach(btn=>{btn.addEventListener('click',()=>{document.querySelectorAll('.filter-btn').forEach(b=>b.classList.remove('active'));btn.classList.add('active');});});
</script>
</body>
</html>
