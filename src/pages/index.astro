        <rect x="115" y="208" width="12" height="6" rx="2" fill="#c9923a" opacity="0.8"/>
        <rect x="115" y="217" width="12" height="6" rx="2" fill="#3ecfbe" opacity="0.7"/>
        <circle cx="134" cy="212" r="3.5" fill="#8b6fff" opacity="0.9"/>
        <circle cx="134" cy="221" r="3.5" fill="#3ecfbe" opacity="0.7"/>
        <g class="alien-arm-l">
          <path d="M96 192 Q72 172 56 148" stroke="#1a2e22" stroke-width="9" stroke-linecap="round" fill="none"/>
