---
import BaseHead from '../components/BaseHead.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700&family=Outfit:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <style is:global>
      *,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
      :root{
        --bg:#07070f;--bg-card:#101020;--bg-card-hover:#141428;
        --border:rgba(255,255,255,0.06);--border-mid:rgba(255,255,255,0.1);
        --gold:#c9923a;--gold-light:#e8b46a;--teal:#3ecfbe;--purple:#8b6fff;
        --text:#ddddef;--text-muted:#55557a;--text-mid:#8888b8;
        --font-display:'Cinzel',serif;--font-body:'Outfit',sans-serif;--font-mono:'JetBrains Mono',monospace;
      }
      html{scroll-behavior:smooth;}
      body{background:var(--bg);color:var(--text);font-family:var(--font-body);font-size:16px;line-height:1.7;min-height:100vh;overflow-x:hidden;}
      #bg-canvas{position:fixed;inset:0;z-index:0;opacity:0.92;pointer-events:none;}
      .vignette{position:fixed;inset:0;z-index:0;pointer-events:none;background:radial-gradient(ellipse at center,transparent 40%,rgba(7,7,15,0.75) 100%);}
      .scanlines{position:fixed;inset:0;z-index:0;pointer-events:none;background:repeating-linear-gradient(0deg,transparent,transparent 3px,rgba(0,0,0,0.08) 3px,rgba(0,0,0,0.08) 4px);opacity:0.4;}

      /* GLITCH */
      .hero-name{position:relative;}
      .glitch-wrap{position:relative;display:inline-block;}
      .glitch-wrap::before,.glitch-wrap::after{content:attr(data-text);position:absolute;top:0;left:0;width:100%;height:100%;font-family:var(--font-display);font-size:inherit;font-weight:inherit;line-height:inherit;letter-spacing:inherit;opacity:0;pointer-events:none;}
      .glitch-wrap::before{color:#3ecfbe;text-shadow:2px 0 #3ecfbe;}
      .glitch-wrap::after{color:#8b6fff;text-shadow:-2px 0 #8b6fff;}
      .glitch-wrap.glitching::before{opacity:0.85;animation:glitch-clip-1 0.4s steps(1) forwards;}
      .glitch-wrap.glitching::after{opacity:0.75;animation:glitch-clip-2 0.4s steps(1) forwards;}
      .glitch-wrap.glitching{animation:glitch-shake 0.4s steps(1) forwards;}
      @keyframes glitch-shake{0%{transform:translate(0);}10%{transform:translate(-3px,1px);}20%{transform:translate(3px,-1px);color:#3ecfbe;}30%{transform:translate(-2px,2px);color:#e8b46a;}40%{transform:translate(2px,-2px);}50%{transform:translate(-3px,0);color:#8b6fff;}60%{transform:translate(3px,1px);color:#3ecfbe;}70%{transform:translate(-1px,-1px);}80%{transform:translate(1px,2px);color:var(--text);}90%{transform:translate(-2px,-1px);}100%{transform:translate(0);color:var(--text);}}
      @keyframes glitch-clip-1{0%{clip-path:inset(40% 0 50% 0);transform:translate(-4px);}20%{clip-path:inset(10% 0 80% 0);transform:translate(4px);}40%{clip-path:inset(70% 0 10% 0);transform:translate(-3px);}60%{clip-path:inset(20% 0 60% 0);transform:translate(3px);}80%{clip-path:inset(55% 0 30% 0);transform:translate(-2px);}100%{clip-path:inset(0 0 100% 0);transform:translate(0);}}
      @keyframes glitch-clip-2{0%{clip-path:inset(60% 0 30% 0);transform:translate(4px);}20%{clip-path:inset(80% 0 5% 0);transform:translate(-4px);}40%{clip-path:inset(5% 0 75% 0);transform:translate(3px);}60%{clip-path:inset(45% 0 40% 0);transform:translate(-3px);}80%{clip-path:inset(25% 0 60% 0);transform:translate(2px);}100%{clip-path:inset(0 0 100% 0);transform:translate(0);}}

      /* NAV */
      nav{position:fixed;top:0;left:0;right:0;z-index:100;display:flex;align-items:center;justify-content:space-between;padding:1.25rem 3rem;border-bottom:1px solid var(--border);background:rgba(7,7,15,0.82);backdrop-filter:blur(16px);}
      .nav-logo{font-family:var(--font-display);font-size:0.82rem;font-weight:600;letter-spacing:0.14em;color:var(--text);text-decoration:none;text-transform:uppercase;}
      .nav-logo span{color:var(--gold-light);}
      .nav-links{display:flex;gap:2.5rem;list-style:none;}
      .nav-links a{font-size:0.78rem;font-weight:500;letter-spacing:0.1em;color:var(--text-mid);text-decoration:none;text-transform:uppercase;transition:color 0.2s;position:relative;}
      .nav-links a::after{content:'';position:absolute;bottom:-4px;left:0;right:0;height:1px;background:var(--gold-light);transform:scaleX(0);transition:transform 0.2s;transform-origin:left;}
      .nav-links a:hover{color:var(--text);}
      .nav-links a:hover::after,.nav-links a.active::after{transform:scaleX(1);}
      .nav-links a.active{color:var(--text);}

      /* HERO */
      .hero{min-height:100vh;display:flex;flex-direction:column;justify-content:center;padding:8rem 3rem 5rem;position:relative;z-index:1;}
      .hero-eyebrow{font-family:var(--font-mono);font-size:0.72rem;color:var(--gold);letter-spacing:0.22em;text-transform:uppercase;margin-bottom:1.5rem;opacity:0;animation:fadeUp 0.6s ease forwards 0.2s;}
      .hero-name{font-family:var(--font-display);font-size:clamp(3.2rem,8vw,7.5rem);font-weight:700;line-height:1.0;letter-spacing:0.02em;color:var(--text);margin-bottom:0.3rem;opacity:0;animation:fadeUp 0.7s ease forwards 0.4s;}
      .hero-alias{font-family:var(--font-display);font-size:clamp(1rem,2.5vw,1.9rem);font-weight:400;color:var(--gold);letter-spacing:0.18em;margin-bottom:2.5rem;opacity:0;animation:fadeUp 0.7s ease forwards 0.55s;}
      .hero-desc{font-size:1rem;color:var(--text-mid);max-width:500px;line-height:1.85;margin-bottom:3rem;opacity:0;animation:fadeUp 0.7s ease forwards 0.7s;}
      .hero-desc strong{color:var(--text);font-weight:500;}
      .hero-cta{display:flex;gap:1rem;flex-wrap:wrap;opacity:0;animation:fadeUp 0.7s ease forwards 0.85s;}
      .hero-tags{display:flex;gap:0.6rem;flex-wrap:wrap;margin-top:2rem;opacity:0;animation:fadeUp 0.6s ease forwards 1s;}
      .tag{font-family:var(--font-mono);font-size:0.62rem;letter-spacing:0.12em;text-transform:uppercase;padding:4px 10px;border:1px solid var(--border-mid);border-radius:2px;color:var(--text-muted);}

      /* ALIEN */
      .hero-astronaut{position:absolute;right:3rem;top:50%;transform:translateY(-50%);width:260px;height:320px;opacity:0;animation:fadeIn 1.5s ease forwards 1.2s;pointer-events:none;filter:drop-shadow(0 8px 32px rgba(62,207,190,0.12)) drop-shadow(0 0 60px rgba(139,111,255,0.08));}
      .astronaut-float{animation:astroFloat 5s ease-in-out infinite;}
      .astronaut-arm-l{animation:armWave 3.5s ease-in-out infinite;transform-origin:88px 162px;}
      .astronaut-arm-r{animation:armDrift 6s ease-in-out infinite 0.8s;transform-origin:174px 170px;}
      .astronaut-bubble{animation:bubblePulse 3s ease-in-out infinite;}
      @keyframes astroFloat{0%,100%{transform:translateY(0) rotate(-2deg);}50%{transform:translateY(-16px) rotate(2deg);}}
      @keyframes armWave{0%,100%{transform:rotate(0deg);}25%{transform:rotate(-12deg);}50%{transform:rotate(6deg);}75%{transform:rotate(-8deg);}}
      @keyframes armDrift{0%,100%{transform:rotate(0deg);}40%{transform:rotate(-10deg);}70%{transform:rotate(5deg);}}
      @keyframes bubblePulse{0%,100%{opacity:0.85;transform:scale(1);}50%{opacity:1;transform:scale(1.04);}}

      /* BUTTONS */
      .btn{display:inline-flex;align-items:center;gap:0.5rem;padding:0.75rem 1.75rem;font-family:var(--font-body);font-size:0.83rem;font-weight:500;letter-spacing:0.06em;text-transform:uppercase;text-decoration:none;border-radius:2px;transition:all 0.2s;cursor:pointer;border:none;}
      .btn-primary{background:var(--gold);color:#07070f;border:1px solid var(--gold);}
      .btn-primary:hover{background:transparent;color:var(--gold);}
      .btn-ghost{background:transparent;color:var(--text-mid);border:1px solid var(--border-mid);}
      .btn-ghost:hover{border-color:var(--text-mid);color:var(--text);}

      /* DIVIDER */
      .divider{width:100%;height:1px;background:linear-gradient(90deg,transparent,var(--border-mid) 20%,var(--border-mid) 80%,transparent);position:relative;z-index:1;}

      /* SECTIONS */
      section{padding:5rem 3rem;position:relative;z-index:1;}
      .section-label{font-family:var(--font-mono);font-size:0.68rem;color:var(--gold);letter-spacing:0.25em;text-transform:uppercase;margin-bottom:0.4rem;}
      .section-title{font-family:var(--font-display);font-size:clamp(1.4rem,3vw,2.1rem);font-weight:600;color:var(--text);margin-bottom:0.6rem;letter-spacing:0.04em;}
      .section-sub{font-size:0.92rem;color:var(--text-muted);max-width:480px;margin-bottom:3rem;line-height:1.7;}
      .section-geo{display:grid;grid-template-columns:1fr auto;gap:2rem;align-items:start;}
      .section-geo-visual{display:flex;align-items:center;justify-content:center;opacity:0.12;padding-top:1rem;}

      /* PROJECTS */
      .projects-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:1.25rem;}
      .project-card{background:var(--bg-card);border:1px solid var(--border);border-radius:3px;padding:1.75rem;transition:all 0.25s ease;position:relative;overflow:hidden;text-decoration:none;color:inherit;display:block;}
      .project-card::before{content:'';position:absolute;top:0;left:0;width:3px;height:100%;background:var(--card-accent,var(--gold));opacity:0;transition:opacity 0.25s;}
      .project-card:hover{background:var(--bg-card-hover);border-color:rgba(201,146,58,0.2);transform:translateY(-2px);}
      .project-card:hover::before{opacity:1;}
      .card-top{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:1rem;}
      .card-icon{font-size:1.4rem;margin-bottom:0.85rem;display:block;}
      .card-tag{font-family:var(--font-mono);font-size:0.6rem;letter-spacing:0.15em;text-transform:uppercase;padding:3px 8px;border-radius:2px;background:rgba(255,255,255,0.04);color:var(--text-muted);}
      .card-status{font-family:var(--font-mono);font-size:0.6rem;letter-spacing:0.1em;text-transform:uppercase;padding:3px 8px;border-radius:2px;}
      .status-active{background:rgba(62,207,190,0.07);color:var(--teal);border:1px solid rgba(62,207,190,0.18);}
      .status-wip{background:rgba(201,146,58,0.07);color:var(--gold-light);border:1px solid rgba(201,146,58,0.18);}
      .status-learning{background:rgba(139,111,255,0.07);color:var(--purple);border:1px solid rgba(139,111,255,0.18);}
      .card-title{font-family:var(--font-display);font-size:1.05rem;font-weight:600;color:var(--text);margin-bottom:0.55rem;letter-spacing:0.04em;}
      .card-desc{font-size:0.84rem;color:var(--text-muted);line-height:1.65;}

      /* NOW */
      .now-layout{display:grid;grid-template-columns:1fr 280px;gap:3rem;align-items:start;}
      .now-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:1rem;}
      .now-item{background:var(--bg-card);border:1px solid var(--border);border-radius:3px;padding:1.4rem;}
      .now-item-label{font-family:var(--font-mono);font-size:0.6rem;letter-spacing:0.18em;text-transform:uppercase;color:var(--gold);margin-bottom:0.55rem;}
      .now-item-title{font-size:0.9rem;font-weight:500;color:var(--text);margin-bottom:0.3rem;}
      .now-item-desc{font-size:0.79rem;color:var(--text-muted);line-height:1.6;}
      .now-geo-aside{display:flex;flex-direction:column;align-items:center;gap:1.5rem;padding-top:0.5rem;}
      .now-geo-aside svg{opacity:0.1;}
      .skills-strip{display:flex;flex-wrap:wrap;gap:0.5rem;margin-top:2rem;}
      .skill-pill{font-family:var(--font-mono);font-size:0.62rem;letter-spacing:0.1em;text-transform:uppercase;padding:5px 10px;border:1px solid var(--border-mid);border-radius:2px;color:var(--text-mid);transition:all 0.2s;}
      .skill-pill:hover{border-color:var(--gold);color:var(--gold-light);}

      /* CURSOR TRAIL */
      .cursor-dot{position:fixed;pointer-events:none;border-radius:50%;z-index:9999;transform:translate(-50%,-50%);transition:opacity 0.4s ease;}

      /* FOOTER */
      footer{padding:2.5rem 3rem;border-top:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1rem;position:relative;z-index:1;}
      .footer-copy{font-family:var(--font-mono);font-size:0.7rem;color:var(--text-muted);letter-spacing:0.06em;}
      .footer-links{display:flex;gap:1.75rem;list-style:none;}
      .footer-links a{font-family:var(--font-mono);font-size:0.7rem;letter-spacing:0.1em;text-transform:uppercase;color:var(--text-muted);text-decoration:none;transition:color 0.2s;}
      .footer-links a:hover{color:var(--gold-light);}

      /* ANIMATIONS */
      @keyframes fadeUp{from{opacity:0;transform:translateY(20px);}to{opacity:1;transform:translateY(0);}}
      @keyframes fadeIn{from{opacity:0;}to{opacity:1;}}
      .reveal{opacity:0;transform:translateY(14px);transition:opacity 0.65s ease,transform 0.65s ease;}
      .reveal.visible{opacity:1;transform:none;}
      .d1{transition-delay:0.1s;}.d2{transition-delay:0.2s;}.d3{transition-delay:0.3s;}

      /* RESPONSIVE */
      @media(max-width:1100px){.now-layout{grid-template-columns:1fr;}.now-geo-aside{display:none;}}
      @media(max-width:900px){.section-geo{display:block;}.section-geo-visual{display:none;}.hero-astronaut{display:none;}}
      @media(max-width:768px){nav{padding:1rem 1.5rem;}section,.hero{padding-left:1.5rem;padding-right:1.5rem;}.hero{padding-top:7rem;padding-bottom:4rem;}.projects-grid,.now-grid{grid-template-columns:1fr;}footer{padding:2rem 1.5rem;flex-direction:column;align-items:flex-start;}}
    </style>
  </head>

  <body>
    <canvas id="bg-canvas"></canvas>
    <div class="vignette"></div>
    <div class="scanlines"></div>

    <nav>
      <a href="/" class="nav-logo">Ivaylo <span>Kolev</span></a>
      <ul class="nav-links">
        <li><a href="/" class="active">Home</a></li>
        <li><a href="/blog">Blog</a></li>
        <li><a href="/about">About</a></li>
      </ul>
    </nav>

    <section class="hero">
      <!-- floating alien -->
      <div class="hero-astronaut" aria-hidden="true">
        <svg class="astronaut-float" viewBox="0 0 260 320" xmlns="http://www.w3.org/2000/svg">
          <defs>
            <radialGradient id="bodyGrad" cx="38%" cy="30%" r="65%">
              <stop offset="0%" stop-color="#2a4a3a"/>
              <stop offset="100%" stop-color="#0e1f18"/>
            </radialGradient>
            <radialGradient id="headGrad" cx="35%" cy="28%" r="65%">
              <stop offset="0%" stop-color="#2e5442"/>
              <stop offset="100%" stop-color="#0e2018"/>
            </radialGradient>
            <radialGradient id="eyeGlowL" cx="50%" cy="50%" r="50%">
              <stop offset="0%" stop-color="#7fffee"/>
              <stop offset="50%" stop-color="#3ecfbe"/>
              <stop offset="100%" stop-color="#0a6060"/>
            </radialGradient>
            <radialGradient id="eyeGlowR" cx="50%" cy="50%" r="50%">
              <stop offset="0%" stop-color="#c8aaff"/>
              <stop offset="50%" stop-color="#8b6fff"/>
              <stop offset="100%" stop-color="#3a1a8a"/>
            </radialGradient>
            <filter id="eyeBloom" x="-60%" y="-60%" width="220%" height="220%">
              <feGaussianBlur stdDeviation="4" result="blur"/>
              <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
            </filter>
            <filter id="bodyGlow" x="-20%" y="-20%" width="140%" height="140%">
              <feGaussianBlur stdDeviation="6" result="blur"/>
              <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
            </filter>
          </defs>
          <ellipse cx="128" cy="148" rx="70" ry="90" fill="rgba(62,207,190,0.03)" filter="url(#bodyGlow)"/>
          <line x1="128" y1="46" x2="140" y2="18" stroke="#1a1a2e" stroke-width="3" stroke-linecap="round"/>
          <line x1="128" y1="46" x2="140" y2="18" stroke="#3ecfbe" stroke-width="1.5" stroke-linecap="round"/>
          <circle cx="140" cy="15" r="7" fill="#0d0d22" stroke="#c9923a" stroke-width="2"/>
          <circle cx="140" cy="15" r="4" fill="#c9923a" opacity="0.9"/>
          <circle cx="138" cy="13" r="1.5" fill="rgba(255,255,255,0.6)"/>
          <circle cx="140" cy="15" r="10" fill="none" stroke="#c9923a" stroke-width="0.8" opacity="0.4" stroke-dasharray="3 3"/>
          <ellipse cx="132" cy="110" rx="56" ry="68" fill="rgba(0,0,0,0.25)"/>
          <ellipse cx="128" cy="106" rx="56" ry="68" fill="url(#headGrad)" stroke="#1a2e22" stroke-width="2.5"/>
          <ellipse cx="112" cy="80" rx="22" ry="16" fill="rgba(62,207,190,0.08)" transform="rotate(-15 112 80)"/>
          <ellipse cx="72" cy="108" rx="10" ry="18" fill="url(#headGrad)" stroke="#1a2e22" stroke-width="2"/>
          <ellipse cx="184" cy="108" rx="10" ry="18" fill="url(#headGrad)" stroke="#1a2e22" stroke-width="2"/>
          <ellipse cx="72" cy="108" rx="5" ry="10" fill="rgba(62,207,190,0.07)"/>
          <ellipse cx="184" cy="108" rx="5" ry="10" fill="rgba(139,111,255,0.07)"/>
          <ellipse cx="106" cy="100" rx="22" ry="18" fill="#060e0a" stroke="#1a2e22" stroke-width="1.5"/>
          <ellipse cx="152" cy="100" rx="22" ry="18" fill="#060e0a" stroke="#1a2e22" stroke-width="1.5"/>
          <ellipse cx="106" cy="100" rx="17" ry="13" fill="url(#eyeGlowL)" filter="url(#eyeBloom)"/>
          <ellipse cx="152" cy="100" rx="17" ry="13" fill="url(#eyeGlowR)" filter="url(#eyeBloom)"/>
          <ellipse cx="108" cy="102" rx="7" ry="9" fill="#001a18"/>
          <ellipse cx="154" cy="102" rx="7" ry="9" fill="#0d0028"/>
          <circle cx="104" cy="96" r="3.5" fill="rgba(255,255,255,0.35)"/>
          <circle cx="150" cy="96" r="3.5" fill="rgba(255,255,255,0.3)"/>
          <circle cx="111" cy="105" r="1.5" fill="rgba(255,255,255,0.15)"/>
          <circle cx="157" cy="105" r="1.5" fill="rgba(255,255,255,0.15)"/>
          <ellipse cx="125" cy="135" rx="5" ry="3" fill="rgba(0,0,0,0.4)"/>
          <ellipse cx="133" cy="135" rx="5" ry="3" fill="rgba(0,0,0,0.4)"/>
          <path d="M112 150 Q129 158 148 150" stroke="#1a2e22" stroke-width="2.5" fill="none" stroke-linecap="round"/>
          <path d="M112 150 Q129 157 148 150" stroke="rgba(62,207,190,0.3)" stroke-width="1.2" fill="none" stroke-linecap="round"/>
          <rect x="114" y="168" width="28" height="18" rx="8" fill="url(#bodyGrad)" stroke="#1a2e22" stroke-width="2"/>
          <ellipse cx="128" cy="218" rx="34" ry="42" fill="url(#bodyGrad)" stroke="#1a2e22" stroke-width="2.5"/>
          <ellipse cx="118" cy="200" rx="14" ry="20" fill="rgba(62,207,190,0.06)" transform="rotate(-10 118 200)"/>
          <line x1="128" y1="188" x2="128" y2="252" stroke="rgba(62,207,190,0.12)" stroke-width="1.5" stroke-dasharray="4 4"/>
          <rect x="112" y="205" width="32" height="22" rx="5" fill="#060e0a" stroke="rgba(62,207,190,0.4)" stroke-width="1.2"/>
          <rect x="115" y="208" width="12" height="6" rx="2" fill="#c9923a" opacity="0.8"/>
          <rect x="115" y="217" width="12" height="6" rx="2" fill="#3ecfbe" opacity="0.7"/>
          <circle cx="134" cy="212" r="3.5" fill="#8b6fff" opacity="0.9"/>
          <circle cx="134" cy="221" r="3.5" fill="#3ecfbe" opacity="0.7"/>
          <g class="astronaut-arm-l">
            <path d="M96 192 Q72 172 56 148" stroke="#1a2e22" stroke-width="9" stroke-linecap="round" fill="none"/>
            <path d="M96 192 Q72 172 56 148" stroke="url(#bodyGrad)" stroke-width="6" stroke-linecap="round" fill="none"/>
            <ellipse cx="52" cy="142" rx="14" ry="12" fill="url(#headGrad)" stroke="#1a2e22" stroke-width="2"/>
            <path d="M43 136 Q38 124 40 116" stroke="#1a2e22" stroke-width="5" stroke-linecap="round" fill="none"/>
            <path d="M43 136 Q39 125 41 117" stroke="url(#bodyGrad)" stroke-width="3" stroke-linecap="round" fill="none"/>
            <path d="M51 132 Q48 120 50 112" stroke="#1a2e22" stroke-width="5" stroke-linecap="round" fill="none"/>
            <path d="M51 132 Q49 121 51 113" stroke="url(#bodyGrad)" stroke-width="3" stroke-linecap="round" fill="none"/>
            <path d="M59 133 Q59 121 61 113" stroke="#1a2e22" stroke-width="5" stroke-linecap="round" fill="none"/>
            <path d="M59 133 Q60 122 62 114" stroke="url(#bodyGrad)" stroke-width="3" stroke-linecap="round" fill="none"/>
            <path d="M65 138 Q68 127 68 119" stroke="#1a2e22" stroke-width="4.5" stroke-linecap="round" fill="none"/>
            <circle cx="40" cy="115" r="3" fill="#3ecfbe" opacity="0.7"/>
            <circle cx="50" cy="111" r="3" fill="#3ecfbe" opacity="0.6"/>
            <circle cx="61" cy="112" r="3" fill="#8b6fff" opacity="0.6"/>
          </g>
          <g class="astronaut-arm-r">
