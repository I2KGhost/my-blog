---
import PageLayout from '../layouts/PageLayout.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<PageLayout title={SITE_TITLE} description={SITE_DESCRIPTION} activeNav="home">

  <style is:global>
    /* GLITCH */
    .hero-name{position:relative;}
    .glitch-wrap{position:relative;display:inline-block;}
    .glitch-wrap::before,.glitch-wrap::after{content:attr(data-text);position:absolute;top:0;left:0;width:100%;height:100%;font-family:var(--font-display);font-size:inherit;font-weight:inherit;line-height:inherit;letter-spacing:inherit;opacity:0;pointer-events:none;}
    .glitch-wrap::before{color:#3ecfbe;text-shadow:2px 0 #3ecfbe;}
    .glitch-wrap::after{color:#8b6fff;text-shadow:-2px 0 #8b6fff;}
    .glitch-wrap.glitching::before{opacity:0.85;animation:glitch-clip-1 0.4s steps(1) forwards;}
    .glitch-wrap.glitching::after{opacity:0.75;animation:glitch-clip-2 0.4s steps(1) forwards;}
    .glitch-wrap.glitching{animation:glitch-shake 0.4s steps(1) forwards;}
    @keyframes glitch-shake{0%{transform:translate(0);}10%{transform:translate(-3px,1px);}20%{transform:translate(3px,-1px);color:#3ecfbe;}30%{transform:translate(-2px,2px);color:#e8b46a;}40%{transform:translate(2px,-2px);}50%{transform:translate(-3px,0);color:#8b6fff;}60%{transform:translate(3px,1px);color:#3ecfbe;}70%{transform:translate(-1px,-1px);}80%{transform:translate(1px,2px);color:var(--text);}90%{transform:translate(-2px,-1px);}100%{transform:translate(0);color:var(--text);}}
    @keyframes glitch-clip-1{0%{clip-path:inset(40% 0 50% 0);transform:translate(-4px);}20%{clip-path:inset(10% 0 80% 0);transform:translate(4px);}40%{clip-path:inset(70% 0 10% 0);transform:translate(-3px);}60%{clip-path:inset(20% 0 60% 0);transform:translate(3px);}80%{clip-path:inset(55% 0 30% 0);transform:translate(-2px);}100%{clip-path:inset(0 0 100% 0);transform:translate(0);}}
    @keyframes glitch-clip-2{0%{clip-path:inset(60% 0 30% 0);transform:translate(4px);}20%{clip-path:inset(80% 0 5% 0);transform:translate(-4px);}40%{clip-path:inset(5% 0 75% 0);transform:translate(3px);}60%{clip-path:inset(45% 0 40% 0);transform:translate(-3px);}80%{clip-path:inset(25% 0 60% 0);transform:translate(2px);}100%{clip-path:inset(0 0 100% 0);transform:translate(0);}}

    /* HERO */
    .hero{min-height:100vh;display:flex;flex-direction:column;justify-content:center;padding:8rem 3rem 5rem;position:relative;z-index:1;}
    .hero-eyebrow{font-family:var(--font-mono);font-size:0.72rem;color:var(--gold);letter-spacing:0.22em;text-transform:uppercase;margin-bottom:1.5rem;opacity:0;animation:fadeUp 0.6s ease forwards 0.2s;}
    .hero-name{font-family:var(--font-display);font-size:clamp(3.2rem,8vw,7.5rem);font-weight:700;line-height:1.0;letter-spacing:0.02em;color:var(--text);margin-bottom:0.3rem;opacity:0;animation:fadeUp 0.7s ease forwards 0.4s;}
    .hero-alias{font-family:var(--font-display);font-size:clamp(1rem,2.5vw,1.9rem);font-weight:400;color:var(--gold);letter-spacing:0.18em;margin-bottom:2.5rem;opacity:0;animation:fadeUp 0.7s ease forwards 0.55s;}
    .hero-desc{font-size:1rem;color:var(--text-mid);max-width:500px;line-height:1.85;margin-bottom:3rem;opacity:0;animation:fadeUp 0.7s ease forwards 0.7s;}
    .hero-desc strong{color:var(--text);font-weight:500;}
    .hero-cta{display:flex;gap:1rem;flex-wrap:wrap;opacity:0;animation:fadeUp 0.7s ease forwards 0.85s;}
    .hero-tags{display:flex;gap:0.6rem;flex-wrap:wrap;margin-top:2rem;opacity:0;animation:fadeUp 0.6s ease forwards 1s;}
    .tag{font-family:var(--font-mono);font-size:0.62rem;letter-spacing:0.12em;text-transform:uppercase;padding:4px 10px;border:1px solid var(--border-mid);border-radius:2px;color:var(--text-muted);}

    /* ALIEN */
    .hero-alien{position:absolute;right:3rem;top:50%;transform:translateY(-50%);width:260px;height:320px;opacity:0;animation:fadeIn 1.5s ease forwards 1.2s;pointer-events:none;filter:drop-shadow(0 8px 32px rgba(62,207,190,0.12)) drop-shadow(0 0 60px rgba(139,111,255,0.08));}
    .alien-float{animation:astroFloat 5s ease-in-out infinite;}
    .alien-arm-l{animation:armWave 3.5s ease-in-out infinite;transform-origin:88px 162px;}
    .alien-arm-r{animation:armDrift 6s ease-in-out infinite 0.8s;transform-origin:174px 170px;}
    .alien-bubble{animation:bubblePulse 3s ease-in-out infinite;}
    @keyframes astroFloat{0%,100%{transform:translateY(0) rotate(-2deg);}50%{transform:translateY(-16px) rotate(2deg);}}
    @keyframes armWave{0%,100%{transform:rotate(0deg);}25%{transform:rotate(-12deg);}50%{transform:rotate(6deg);}75%{transform:rotate(-8deg);}}
    @keyframes armDrift{0%,100%{transform:rotate(0deg);}40%{transform:rotate(-10deg);}70%{transform:rotate(5deg);}}
    @keyframes bubblePulse{0%,100%{opacity:0.85;transform:scale(1);}50%{opacity:1;transform:scale(1.04);}}

    /* PROJECTS */
    .section-geo{display:grid;grid-template-columns:1fr auto;gap:2rem;align-items:start;}
    .section-geo-visual{display:flex;align-items:center;justify-content:center;opacity:0.12;padding-top:1rem;}
    .projects-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:1.25rem;}

    /* NOW */
    .now-layout{display:grid;grid-template-columns:1fr 280px;gap:3rem;align-items:start;}
    .now-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:1rem;}
    .now-item{background:var(--bg-card);border:1px solid var(--border);border-radius:3px;padding:1.4rem;}
    .now-item-label{font-family:var(--font-mono);font-size:0.6rem;letter-spacing:0.18em;text-transform:uppercase;color:var(--gold);margin-bottom:0.55rem;}
    .now-item-title{font-size:0.9rem;font-weight:500;color:var(--text);margin-bottom:0.3rem;}
    .now-item-desc{font-size:0.79rem;color:var(--text-muted);line-height:1.6;}
    .now-geo-aside{display:flex;flex-direction:column;align-items:center;gap:1.5rem;padding-top:0.5rem;}
    .now-geo-aside svg{opacity:0.1;}
    .skills-strip{display:flex;flex-wrap:wrap;gap:0.5rem;margin-top:2rem;}
    .skill-pill{font-family:var(--font-mono);font-size:0.62rem;letter-spacing:0.1em;text-transform:uppercase;padding:5px 10px;border:1px solid var(--border-mid);border-radius:2px;color:var(--text-mid);transition:all 0.2s;}
    .skill-pill:hover{border-color:var(--gold);color:var(--gold-light);}

    @media(max-width:1100px){.now-layout{grid-template-columns:1fr;}.now-geo-aside{display:none;}}
    @media(max-width:900px){.section-geo{display:block;}.section-geo-visual{display:none;}.hero-alien{display:none;}}
    @media(max-width:768px){.hero{padding-top:7rem;padding-bottom:4rem;}.projects-grid,.now-grid{grid-template-columns:1fr;}}
  </style>

  <!-- HERO -->
